# ==========================================
# 1. Global Block Protocols (Ignore All)
# ==========================================
# Ignore all files and directories by default
*

# ==========================================
# 2. Precision Whitelist Access (Allow Core Files)
# ==========================================
# Allow tracking of this config file itself
!.gitignore

# Allow tracking of all core Python scripts
!*.py

# Allow tracking of all LaTeX templates and class packages
!*.tex
!*.cls
!*.sty

# Allow tracking of documentation and markdown files
!README.md
!*.md

# ==========================================
# 3. Subdirectory Access Control (If applicable)
# ==========================================
# If your scripts are inside a subfolder, uncomment the line below to grant access:
#!src/